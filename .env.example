# Database (SQLite — no server needed, stored as a local file)
DATABASE_URL=sqlite+aiosqlite:///data/dexter.db

# Qdrant (embedded mode — stored as a local directory)
QDRANT_PATH=data/qdrant
QDRANT_COLLECTION_NAME=dexter_memory

# Single LLM configuration (Gemini by default, OpenAI-compatible API)
DEFAULT_LLM_PROVIDER=gemini
LLM_API_KEY=your-api-key-here
LLM_MODEL=gemini-2.5-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Auth
SECRET_KEY=change-me-to-a-long-random-string
MAX_PROMPT_CHARS=12000
MAX_TOOL_INPUT_CHARS=6000

# Observability
SENTRY_DSN=

# Optional search
SERPAPI_KEY=

# Agent file tools (must exist on disk; paths are confined under this directory)
# Windows example: C:/Users/YourName/dexter_agent_files
# Linux/Mac example: /tmp/dexter_agent_files
AGENT_FILES_ROOT=C:/Users/YourName/dexter_agent_files

# Optional email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# Optional Google Calendar
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Environment
ENVIRONMENT=dev
CORS_ORIGINS=*
ENABLE_SHELL_TOOL=false
ENABLE_DESKTOP_CONTROL=false

TTS_VOICE=en-US-ChristopherNeural
