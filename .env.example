# Docker Compose Postgres (also used by DATABASE_URL when running via compose)
POSTGRES_PASSWORD=dexter

# Database
DATABASE_URL=postgresql+asyncpg://dexter:dexter@localhost:5432/dexter

# Redis (broker + cache + rate limiting)
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=dexter_memory

# Single LLM configuration (Gemini by default, OpenAI-compatible API)
DEFAULT_LLM_PROVIDER=gemini
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Auth
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_PROMPT_CHARS=12000
MAX_TOOL_INPUT_CHARS=6000
RATE_LIMIT_PER_MINUTE=60

# Observability
SENTRY_DSN=

# Optional search
SERPAPI_KEY=

# Agent file tools (must exist on disk; paths are confined under this directory)
AGENT_FILES_ROOT=/tmp/dexter_agent_files

# Optional email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# Optional Google Calendar
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Environment
ENVIRONMENT=dev
CORS_ORIGINS=*
